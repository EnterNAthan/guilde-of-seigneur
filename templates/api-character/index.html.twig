{% extends 'base.html.twig' %}

{% block title %}Liste des Characters - La Guilde des Seigneurs{% endblock %}

{% block body %}
    <h1>Les Membres de la Guilde</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Type</th>
                <th>Nom</th>
                <th>Surnom</th>
                <th>Caste</th>
                <th>Connaissance</th>
                <th>Intelligence</th>
                <th>Force</th>
                <th>Vie</th>
                <th>Creation</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for character in characters %}
            <tr>
                <td>
                    {% if character.kind == 'Dame' %}
                        <span class="dame-badge">{{ character.kind }}</span>
                    {% else %}
                        {{ character.kind }}
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('api_character_show', {'identifier': character.identifier}) }}">{{ character.name }}</a>
                </td>
                <td>{{ character.surname }}</td>
                <td>{{ character.caste }}</td>
                <td>{{ character.knowledge }}</td>
                <td>{{ character.intelligence }}</td>
                <td>{{ character.strength }}</td>
                <td>{{ character.life }}</td>
                <td>{{ character.creation ? character.creation|date('d/m/Y') : '' }}</td>
                <td>
                    <div class="actions">
                        <a href="{{ path('api_character_edit', {'identifier': character.identifier}) }}" class="btn-medieval btn-gold" style="padding: 4px 10px; font-size: 0.7rem;">Modifier</a>
                        <form method="post" action="{{ path('api_character_delete', {'identifier': character.identifier}) }}" onsubmit="return confirm('Etes-vous sur de vouloir bannir ce membre de la Guilde ?');">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ character.identifier) }}">
                            <button type="submit" class="btn-medieval btn-blood" style="padding: 4px 10px; font-size: 0.7rem;">Bannir</button>
                        </form>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="10">La Guilde est vide... Aucun membre trouve.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div style="text-align: center; margin-top: 2rem;">
        <a href="{{ path('api_character_new') }}" class="btn-medieval btn-forest">Recruter un nouveau membre</a>
    </div>
{% endblock %}
