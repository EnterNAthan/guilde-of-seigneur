{% extends 'base.html.twig' %}

{% block title %}Modifier - La Guilde des Seigneurs{% endblock %}

{% block body %}
    <h1>Modifier le membre</h1>

    <div class="card-medieval">
        {{ include('api-character/_form.html.twig', {'button_label': 'Mettre a jour'}) }}

        <div style="display: flex; gap: 10px; margin-top: 1rem; justify-content: center; flex-wrap: wrap;">
            <a href="{{ path('api_character_index') }}" class="btn-medieval btn-stone">Retour a la Guilde</a>
        </div>

        <div style="margin-top: 1rem; text-align: center;">
            {{ include('api-character/_delete_form.html.twig') }}
        </div>
    </div>
{% endblock %}
