{% extends 'base.html.twig' %}

{% block title %}Connexion - La Guilde des Seigneurs{% endblock %}

{% block body %}
    <h1>Entrez dans la Guilde</h1>

    <div class="card-medieval">
        <form action="{{ path('api_login') }}" method="post">
            {% if app.user %}
                <div style="text-align: center; margin-bottom: 1rem; color: var(--gold);">
                    Vous etes connecte en tant que {{ app.user.userIdentifier }},
                    <a href="{{ logout_path() }}" style="color: #e88bc4;">Quitter la Guilde</a>
                </div>
            {% endif %}

            <label for="username">Email</label>
            <input type="email" name="_username" id="username" class="form-control" autocomplete="email" required autofocus>

            <label for="password">Mot de passe</label>
            <input type="password" name="_password" id="password" class="form-control" autocomplete="current-password" required>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <div style="text-align: center; margin-top: 1.5rem;">
                <button class="btn-medieval btn-gold" type="submit">Se connecter</button>
            </div>
        </form>
    </div>
{% endblock %}
